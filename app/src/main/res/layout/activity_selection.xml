<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F6FF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="74dp"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="30dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="170dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/pickday_card_white"
                    app:backgroundTint="@null"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:minEms="0"
                    android:padding="0dp"
                    android:text="←"
                    android:textAllCaps="false"
                    android:textColor="#252538"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="8dp"
                    android:text="●──●──③"
                    android:textColor="#6A4DFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="50dp"
                    android:includeFontPadding="false"
                    android:text="후보 날짜 &amp; 시간 선택"
                    android:textColor="#232336"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="90dp"
                    android:includeFontPadding="false"
                    android:text="참가자들이 가능한 시간을 선택해보세요"
                    android:textColor="#8D8AA5"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="34dp"
                    android:scaleType="fitCenter"
                    android:scaleX="1.75"
                    android:scaleY="1.75"
                    android:translationX="-18dp"
                    android:translationY="10dp"
                    android:src="@drawable/selection_charactor" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="120dp"
                    android:layout_marginLeft="10dp"
                    android:background="@drawable/pickday_card_glass"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="5dp"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="▣"
                        android:textColor="#6A4DFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:includeFontPadding="false"
                        android:text="양일 이상을 선택할수록\n더 좋은 날짜를 찾을 확률이 높아져요!"
                        android:textColor="#6A4DFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/pickday_card_white"
                android:orientation="vertical"
                android:padding="15dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="날짜 선택"
                        android:textColor="#232336"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnCalendarToggle"
                        android:layout_width="92dp"
                        android:layout_height="34dp"
                        android:background="@drawable/pickday_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="▣  달력 보기"
                        android:textColor="#6A4DFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="92dp"
                    android:layout_marginTop="8dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutCandidateDates"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/date0521"
                            style="@style/PickDayDateChip"
                            android:background="@drawable/pickday_card_soft">

                            <TextView style="@style/PickDayDateTopText" android:text="오늘" />
                            <TextView style="@style/PickDayDateMainText" android:text="5.21" />
                            <TextView style="@style/PickDayDateSubText" android:text="수" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/date0522"
                            style="@style/PickDayDateChip">

                            <TextView style="@style/PickDayDateTopText" android:text="내일" />
                            <TextView style="@style/PickDayDateMainText" android:text="5.22" />
                            <TextView style="@style/PickDayDateSubText" android:text="목" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/date0523"
                            style="@style/PickDayDateChip">

                            <TextView style="@style/PickDayDateTopText" android:text="" />
                            <TextView style="@style/PickDayDateMainText" android:text="5.23" />
                            <TextView style="@style/PickDayDateSubText" android:text="금" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/date0524"
                            style="@style/PickDayDateChip"
                            android:background="@drawable/pickday_unselected">

                            <TextView style="@style/PickDayDateTopTextSelected" android:text="" />
                            <TextView style="@style/PickDayDateMainText" android:text="5.24" />
                            <TextView style="@style/PickDayDateSubText" android:text="토" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/date0525"
                            style="@style/PickDayDateChip">

                            <TextView style="@style/PickDayDateTopText" android:text="" />
                            <TextView style="@style/PickDayDateMainText" android:text="5.25" />
                            <TextView style="@style/PickDayDateSubText" android:text="일" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/date0526"
                            style="@style/PickDayDateChip">

                            <TextView style="@style/PickDayDateTopText" android:text="" />
                            <TextView style="@style/PickDayDateMainText" android:text="5.26" />
                            <TextView style="@style/PickDayDateSubText" android:text="월" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/date0527"
                            style="@style/PickDayDateChip"
                            android:background="@drawable/pickday_selected"
                            android:layout_marginEnd="0dp">

                            <TextView style="@style/PickDayDateTopTextSelected" android:text="" />
                            <TextView style="@style/PickDayDateMainTextSelected" android:text="5.27" />
                            <TextView style="@style/PickDayDateSubTextSelected" android:text="화" />
                            <TextView style="@style/PickDayDateCheckText" android:text="✓" />
                        </LinearLayout>

                    </LinearLayout>
                </HorizontalScrollView>

                <include
                    android:id="@+id/selectionCalendar"
                    layout="@layout/view_pickday_calendar"
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:layout_marginTop="10dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvDateCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="✓ 최대 10개까지 선택할 수 있어요 (2/10)"
                    android:textColor="#9A96B4"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:background="#EEEAFB" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="시간대 선택  "
                    android:textColor="#232336"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:id="@+id/layoutTimeOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:columnCount="2">

                    <TextView
                        android:id="@+id/timeMorning"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="7dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/pickday_unselected"
                        android:gravity="center"
                        android:text="○  오전\n(09:00~12:00)"
                        android:textColor="#59566F"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/timeAfternoon"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="7dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/pickday_unselected"
                        android:gravity="center"
                        android:text="○  오후\n(12:00~15:00)"
                        android:textColor="#59566F"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/timeLateAfternoon"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="7dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/pickday_unselected"
                        android:gravity="center"
                        android:text="○  늦은 오후\n(15:00~18:00)"
                        android:textColor="#59566F"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/timeEvening"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="7dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/pickday_unselected"
                        android:gravity="center"
                        android:text="○  저녁\n(18:00~21:00)"
                        android:textColor="#59566F"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/timeLateEvening"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_marginEnd="7dp"
                        android:background="@drawable/pickday_unselected"
                        android:gravity="center"
                        android:text="○  늦은 저녁\n(21:00~24:00)"
                        android:textColor="#59566F"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/timeAny"
                        android:layout_width="0dp"
                        android:layout_height="58dp"
                        android:layout_columnWeight="1"
                        android:layout_marginStart="7dp"
                        android:background="@drawable/pickday_unselected"
                        android:gravity="center"
                        android:text="○  상관없음"
                        android:textColor="#59566F"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </GridLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/pickday_card_soft"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✦  TIP\n오후, 저녁 시간대가 가장 많은 선택을 받을 확률이 높아요!"
                        android:textColor="#6A4DFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:gravity="center"
                        android:text="🗓️"
                        android:textSize="32sp" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:background="#EEEAFB" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="제외할 날짜 (선택)"
                        android:textColor="#232336"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvExcludeCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0개 선택  ⌄"
                        android:textColor="#6A4DFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="모임이 어려운 날짜가 있다면 선택해주세요"
                    android:textColor="#8D8AA5"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:layout_marginTop="10dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layoutExcludeDates"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                        <TextView android:id="@+id/exclude0529" style="@style/PickDayExcludeDateChip" android:text="5.29\n목" />
                        <TextView android:id="@+id/exclude0530" style="@style/PickDayExcludeDateChip" android:text="5.30\n금" />
                        <TextView android:id="@+id/exclude0531" style="@style/PickDayExcludeDateChip" android:text="5.31\n토" />
                        <TextView android:id="@+id/exclude0601" style="@style/PickDayExcludeDateChip" android:text="6.1\n일" />
                        <TextView android:id="@+id/exclude0605" style="@style/PickDayExcludeDateChip" android:text="6.5\n목" />
                        <TextView android:id="@+id/exclude0606" style="@style/PickDayExcludeDateChip" android:text="6.6\n금" />
                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/pickday_button_primary"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="다음: 미리 보기   →"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold" />

</FrameLayout>