<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="30dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- 상단 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="76dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/pickday_card_white"
                app:backgroundTint="@null"
                android:gravity="center"
                android:text="←"
                android:textColor="#252538"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:includeFontPadding="false"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="6dp"
                android:text="가능한 날짜 달력"
                android:textColor="#232336"
                android:textSize="22sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="42dp"
                android:text="날짜를 선택하면 아래에 시간이 표시돼요"
                android:textColor="#8D8AA5"
                android:textSize="11sp"
                android:textStyle="bold"
                android:includeFontPadding="false" />

        </FrameLayout>

        <!-- 본문 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/pickday_card_white"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- 범례 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:gravity="end|center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● 선택됨"
                    android:textColor="#5B4CDB"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="● 선택 가능"
                    android:textColor="#B7A5FF"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="● 불가능"
                    android:textColor="#B8B8C8"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 재사용 달력 -->
            <include
                android:id="@+id/responseCalendar"
                layout="@layout/view_pickday_calendar"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvDateCount"
                android:layout_width="match_parent"
                android:layout_height="30dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/pickday_card_soft"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:includeFontPadding="false"
                android:text="▣ 최대 10개까지 선택할 수 있어요 (0/10)"
                android:textColor="#8D8AA5"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- 선택한 날짜 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="선택한 날짜"
                    android:layout_marginLeft="10dp"
                    android:textColor="#232336"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:id="@+id/tvSelectedDateCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0개 선택  ^"
                    android:textColor="#6A4DFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:scrollbars="none"
                android:padding="10dp"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/layoutSelectedDates"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- 시간 선택 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="5dp"
                android:text="시간 선택  (복수 선택 가능)"
                android:textColor="#232336"
                android:textSize="14sp"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/layoutTimeOptions"
                android:layout_width="match_parent"
                android:layout_height="112dp"
                android:layout_marginTop="6dp"
                android:columnCount="3">

                <TextView
                    android:id="@+id/timeMorning"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="5dp"
                    android:layout_marginBottom="7dp"
                    android:background="@drawable/pickday_unselected"
                    android:gravity="center"
                    android:text="○ 오전\n09:00~12:00"
                    android:textColor="#59566F"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/timeAfternoon"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="5dp"
                    android:layout_marginBottom="7dp"
                    android:background="@drawable/pickday_unselected"
                    android:gravity="center"
                    android:text="○ 오후\n12:00~15:00"
                    android:textColor="#59566F"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/timeLateAfternoon"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_columnWeight="1"
                    android:layout_marginBottom="7dp"
                    android:background="@drawable/pickday_unselected"
                    android:gravity="center"
                    android:text="○ 늦은 오후\n15:00~18:00"
                    android:textColor="#59566F"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/timeEvening"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/pickday_unselected"
                    android:gravity="center"
                    android:text="○ 저녁\n18:00~21:00"
                    android:textColor="#59566F"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/timeLateEvening"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/pickday_unselected"
                    android:gravity="center"
                    android:text="○ 늦은 저녁\n21:00~24:00"
                    android:textColor="#59566F"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/timeAny"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_columnWeight="1"
                    android:background="@drawable/pickday_unselected"
                    android:gravity="center"
                    android:text="○ 상관없음\n하루 종일 가능"
                    android:textColor="#59566F"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </GridLayout>

            <!-- TIP -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="7dp"
                android:background="@drawable/pickday_card_soft"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="15dp"
                android:paddingEnd="15dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💡  TIP\n오후, 저녁 시간대가 가장 많은 선택을 받을 확률이 높아요!"
                    android:textColor="#6A4DFF"
                    android:textSize="9sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="🗓️"
                    android:textSize="28sp" />
            </LinearLayout>

            <!-- 제외할 날짜 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="24dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_weight="1"
                    android:text="제외할 날짜  (선택)"
                    android:layout_marginLeft="10dp"
                    android:textColor="#232336"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvExcludeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0개 선택  ˅"
                    android:textColor="#6A4DFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="10dp"
                android:scrollbars="none"
                android:overScrollMode="never">

                <LinearLayout
                    android:id="@+id/layoutExcludeDates"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/exclude0529" style="@style/PickDayExcludeDateChip" android:text="5.29\n목" />
                    <TextView android:id="@+id/exclude0530" style="@style/PickDayExcludeDateChip" android:text="5.30\n금" />
                    <TextView android:id="@+id/exclude0531" style="@style/PickDayExcludeDateChip" android:text="5.31\n토" />
                    <TextView android:id="@+id/exclude0601" style="@style/PickDayExcludeDateChip" android:text="6.1\n일" />
                    <TextView android:id="@+id/exclude0602" style="@style/PickDayExcludeDateChip" android:text="6.2\n월" />
                    <TextView android:id="@+id/exclude0603" style="@style/PickDayExcludeDateChip" android:text="6.3\n화" />
                    <TextView android:id="@+id/exclude0604" style="@style/PickDayExcludeDateChip" android:text="6.4\n수" />

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>

        <TextView
            android:id="@+id/btnComplete"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/pickday_button_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="선택 완료                         →"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

    </LinearLayout>

</FrameLayout>