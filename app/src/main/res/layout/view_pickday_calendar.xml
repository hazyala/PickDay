<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/calendarContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/pickday_card_soft"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvCalendarTitle"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="2025년 5월"
        android:layout_marginBottom="10dp"
        android:textColor="#232336"
        android:textSize="12sp"
        android:textStyle="bold" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:columnCount="7">

        <TextView style="@style/PickDayCalendarWeekText" android:text="일" />
        <TextView style="@style/PickDayCalendarWeekText" android:text="월" />
        <TextView style="@style/PickDayCalendarWeekText" android:text="화" />
        <TextView style="@style/PickDayCalendarWeekText" android:text="수" />
        <TextView style="@style/PickDayCalendarWeekText" android:text="목" />
        <TextView style="@style/PickDayCalendarWeekText" android:text="금" />
        <TextView style="@style/PickDayCalendarWeekText" android:text="토" />
    </GridLayout>

    <GridLayout
        android:id="@+id/calendarGrid"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="5dp"
        android:columnCount="7"
        android:rowCount="6">

        <TextView style="@style/PickDayCalendarEmptyText" />
        <TextView style="@style/PickDayCalendarEmptyText" />
        <TextView style="@style/PickDayCalendarEmptyText" />
        <TextView style="@style/PickDayCalendarEmptyText" />

        <TextView android:id="@+id/day1" style="@style/PickDayCalendarDayText" android:text="1" />
        <TextView android:id="@+id/day2" style="@style/PickDayCalendarDayText" android:text="2" />
        <TextView android:id="@+id/day3" style="@style/PickDayCalendarDayText" android:text="3" />
        <TextView android:id="@+id/day4" style="@style/PickDayCalendarDayText" android:text="4" />
        <TextView android:id="@+id/day5" style="@style/PickDayCalendarDayText" android:text="5" />
        <TextView android:id="@+id/day6" style="@style/PickDayCalendarDayText" android:text="6" />
        <TextView android:id="@+id/day7" style="@style/PickDayCalendarDayText" android:text="7" />
        <TextView android:id="@+id/day8" style="@style/PickDayCalendarDayText" android:text="8" />
        <TextView android:id="@+id/day9" style="@style/PickDayCalendarDayText" android:text="9" />
        <TextView android:id="@+id/day10" style="@style/PickDayCalendarDayText" android:text="10" />
        <TextView android:id="@+id/day11" style="@style/PickDayCalendarDayText" android:text="11" />
        <TextView android:id="@+id/day12" style="@style/PickDayCalendarDayText" android:text="12" />
        <TextView android:id="@+id/day13" style="@style/PickDayCalendarDayText" android:text="13" />
        <TextView android:id="@+id/day14" style="@style/PickDayCalendarDayText" android:text="14" />
        <TextView android:id="@+id/day15" style="@style/PickDayCalendarDayText" android:text="15" />
        <TextView android:id="@+id/day16" style="@style/PickDayCalendarDayText" android:text="16" />
        <TextView android:id="@+id/day17" style="@style/PickDayCalendarDayText" android:text="17" />
        <TextView android:id="@+id/day18" style="@style/PickDayCalendarDayText" android:text="18" />
        <TextView android:id="@+id/day19" style="@style/PickDayCalendarDayText" android:text="19" />
        <TextView android:id="@+id/day20" style="@style/PickDayCalendarDayText" android:text="20" />
        <TextView android:id="@+id/day21" style="@style/PickDayCalendarDayText" android:text="21" />
        <TextView android:id="@+id/day22" style="@style/PickDayCalendarDayText" android:text="22" />
        <TextView android:id="@+id/day23" style="@style/PickDayCalendarDayText" android:text="23" />
        <TextView android:id="@+id/day24" style="@style/PickDayCalendarDayText" android:text="24" />
        <TextView android:id="@+id/day25" style="@style/PickDayCalendarDayText" android:text="25" />
        <TextView android:id="@+id/day26" style="@style/PickDayCalendarDayText" android:text="26" />
        <TextView android:id="@+id/day27" style="@style/PickDayCalendarDayText" android:text="27" />
        <TextView android:id="@+id/day28" style="@style/PickDayCalendarDayText" android:text="28" />
        <TextView android:id="@+id/day29" style="@style/PickDayCalendarDayText" android:text="29" />
        <TextView android:id="@+id/day30" style="@style/PickDayCalendarDayText" android:text="30" />
        <TextView android:id="@+id/day31" style="@style/PickDayCalendarDayText" android:text="31" />

    </GridLayout>

</LinearLayout>