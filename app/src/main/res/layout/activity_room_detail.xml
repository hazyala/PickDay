<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F7FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="30dp"
            android:paddingEnd="20dp"
            android:paddingBottom="22dp">

            <!-- 상단 헤더 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="17dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnBack"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/pickday_card_white"
                    app:backgroundTint="@null"
                    android:gravity="center"
                    android:padding="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="←"
                    android:textAllCaps="false"
                    android:textColor="#202033"
                    android:textSize="24sp"
                    android:includeFontPadding="false"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/imgRoomCharacter"
                    android:layout_width="210dp"
                    android:layout_height="210dp"
                    android:layout_gravity="top|end"
                    android:layout_marginEnd="-12dp"
                    android:translationY="-10dp"
                    android:src="@drawable/roomdeatil_charactor"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="72dp"
                    android:layout_height="28dp"
                    android:layout_marginTop="55dp"
                    android:background="@drawable/pickday_card_glass"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="진행 중"
                    android:textColor="#6A4DFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="80dp"
                    android:text="동아리 MT  ⛺"
                    android:textColor="#202033"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="120dp"
                    android:text="모두가 가능한 최고의 날을 찾아봐요!"
                    android:textColor="#8B8AA8"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="140dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▣  마감일 5.27 (화) 오후 11:59"
                        android:textColor="#5B4CDB"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:text="♙  인원 2~20명"
                        android:textColor="#5B4CDB"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <!-- 내 응답 카드 -->

            <!-- 진행 현황 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/pickday_card_white"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="진행 현황"
                        android:layout_marginLeft="10dp"
                        android:includeFontPadding="false"
                        android:textColor="#5B4CDB"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.23 (금) 오후 8:30 기준"
                        android:includeFontPadding="false"
                        android:textColor="#8B8AA8"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="참여자\n6명/ 12명"
                        android:textColor="#202033"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="응답 완료\n4명 (66%)"
                        android:textColor="#202033"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="응답 대기\n2명 (34%)"
                        android:textColor="#202033"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="최종 확정 🚩\n미정"
                        android:textColor="#202033"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 진행률 바 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="27dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/pickday_card_soft"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="66"
                            android:background="@drawable/pickday_button_primary" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="34" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="66%"
                        android:textColor="#202033"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 알림 배너 -->
            </LinearLayout>

            <!-- 가장 유력한 날짜 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/pickday_card_white"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="가장 유력한 날짜  ⓘ"
                    android:textColor="#5B4CDB"
                    android:includeFontPadding="false"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="104dp"
                    android:layout_marginTop="5dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/pickday_selected"
                            android:gravity="center"
                            android:text="5.24 (토)   1순위\n6명\n100%\n● ● ● ● ● ●"
                            android:textColor="#5B4CDB"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/pickday_unselected"
                            android:gravity="center"
                            android:text="5.25 (일)\n4명\n67%\n● ● ● ● ○ ○"
                            android:textColor="#77748E"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/pickday_unselected"
                            android:gravity="center"
                            android:text="5.26 (월)\n3명\n50%\n● ● ● ○ ○ ○"
                            android:textColor="#77748E"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/pickday_unselected"
                            android:gravity="center"
                            android:text="5.27 (화)\n1명\n17%\n● ○ ○ ○ ○ ○"
                            android:textColor="#77748E"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 시간 선호도 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/pickday_card_white"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="시간 선호도"
                    android:includeFontPadding="false"
                    android:textColor="#5B4CDB"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="오후 (12:00~15:00)\t\t\t\t\t\t\t\t\t\t━━━━━━━━━━━━━  \t\t\t5명"
                    android:textColor="#77748E"
                    android:textSize="10sp"
                    android:includeFontPadding="false"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="저녁 (18:00~21:00)\t\t\t\t\t\t\t\t\t\t━━━━━━━━━━  \t\t\t4명"
                    android:textColor="#77748E"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="늦은 오후 (15:00~18:00)\t\t\t\t\t\t\t━━━━━  \t\t\t2명"
                    android:textColor="#77748E"
                    android:includeFontPadding="false"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="오전 (09:00~12:00)\t\t\t\t\t\t\t\t\t\t━━━  \t\t\t1명"
                    android:textColor="#77748E"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="상관없음\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t━━━  \t\t\t1명"
                    android:textColor="#C9C6D8"
                    android:includeFontPadding="false"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 참여자 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/pickday_card_white"
                android:orientation="vertical"
                android:padding="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="참여자 (6/12)"
                        android:textColor="#5B4CDB"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체 보기  ›"
                        android:textColor="#6A4DFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="94dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                        <TextView android:layout_width="60dp" android:layout_height="match_parent" android:gravity="center" android:text="👧\n나 \n미응답" android:textSize="12sp" android:textStyle="bold" android:textColor="#77748E"/>
                        <TextView android:layout_width="60dp" android:layout_height="match_parent" android:gravity="center" android:text="🐱\n지우\n응답 완료" android:textSize="12sp" android:textStyle="bold" android:textColor="#77748E"/>
                        <TextView android:layout_width="60dp" android:layout_height="match_parent" android:gravity="center" android:text="👦\n현우\n응답 완료" android:textSize="12sp" android:textStyle="bold" android:textColor="#77748E"/>
                        <TextView android:layout_width="60dp" android:layout_height="match_parent" android:gravity="center" android:text="🐰\n수빈\n응답 완료" android:textSize="12sp" android:textStyle="bold" android:textColor="#77748E"/>
                        <TextView android:layout_width="60dp" android:layout_height="match_parent" android:gravity="center" android:text="👤\n민재\n응답 대기" android:textSize="12sp" android:textStyle="bold" android:textColor="#77748E"/>
                        <TextView android:layout_width="60dp" android:layout_height="match_parent" android:gravity="center" android:text="👤\n서연\n응답 대기" android:textSize="12sp" android:textStyle="bold" android:textColor="#77748E"/>

                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

        </LinearLayout>

    <!-- 하단 고정 버튼 -->
    <TextView
        android:id="@+id/btnChangeResponse"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/pickday_button_primary"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="나의 응답 선택하기        →"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

</FrameLayout>