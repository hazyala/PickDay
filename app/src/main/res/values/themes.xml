<resources>

    <style name="Base.Theme.PickDay" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/notosanskr_regular</item>
        <item name="fontFamily">@font/notosanskr_regular</item>

        <item name="colorPrimary">@color/pickday_purple</item>
        <item name="colorPrimaryVariant">@color/pickday_purple_dark</item>
        <item name="colorOnPrimary">@color/pickday_text_white</item>

        <item name="android:windowBackground">@color/pickday_background</item>
        <item name="android:navigationBarColor">@color/pickday_background</item>
        <item name="android:statusBarColor">@color/pickday_background</item>

        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.PickDay" parent="Base.Theme.PickDay" />

    <style name="PickDayCalendarWeekText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">#9A96B0</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PickDayCalendarDayText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">#252538</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="PickDayCalendarEmptyText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
    </style>

    <style name="PickDayExcludeDateChip">
        <item name="android:layout_width">58dp</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/pickday_unselected</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#59566F</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="PickDayDateChip">
        <item name="android:layout_width">58dp</item>
        <item name="android:layout_height">76dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/pickday_unselected</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="PickDayDateTopText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">14dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#9A96B4</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="PickDayDateMainText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#59566F</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="PickDayDateSubText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#59566F</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="PickDayDateTopTextSelected">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">8dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">8sp</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="PickDayDateMainTextSelected">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#6A4DFF</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="PickDayDateSubTextSelected">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#6A4DFF</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="PickDayDateCheckText">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:background">@drawable/pickday_button_primary</item>
        <item name="android:includeFontPadding">false</item>
    </style>
</resources>